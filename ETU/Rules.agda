module ETU.Rules where

open import Prelude
open import WSLN

open import ETU.Syntax
open import ETU.Judgement

----------------------------------------------------------------------
-- Provable judgements in context, using cofinite quantification
-- instead of freshness assumptions
----------------------------------------------------------------------
infix 1 _вҠў_
data Ok : Cx вҶ’ Set
data _вҠў_ (О“ : Cx) : Jg вҶ’ Set

{- Some rules include helper hypotheses that aid proofs by structural
induction. -}

data Ok where
  -----------------------------
  -- Well-formed contexts: Ok О“
  -----------------------------
  okв—Ү : Ok в—Ү
  okвЁҹ :
    {l : в„•}
    {О“ : Cx}
    {A : Ty}
    {x : рқ”ё}
    (qвӮҖ : О“ вҠў A вҰӮ l)
    (qвӮҒ : x # О“)
    -- helper hypothesis
    (h : Ok О“)
    вҶ’ -----------------
    Ok (О“ вЁҹ x вҲ¶[ l ] A)

data _вҠў_  О“ where
  ------------------------------------
  -- Well-formed terms: О“ вҠў a вҲ¶[ l ] A
  ------------------------------------
  вҠўconv :
    {l : в„•}
    {a : Tm}
    {A A' : Ty}
    (qвӮҖ : О“ вҠў a вҲ¶[ l ] A)
    (qвӮҒ : О“ вҠў A пјқ A' вҰӮ l)
    вҶ’ ---------------------
    О“ вҠў a вҲ¶[ l ] A'

  вҠўрқҗҜ :
    {l : в„•}
    {A : Ty}
    {x : рқ”ё}
    (qвӮҖ : Ok О“)
    (qвӮҒ : (x , A , l) isIn О“)
    вҶ’ -----------------------
    О“ вҠў рқҗҜ x вҲ¶[ l ] A

  вҠўрқҗ” :
    {l : в„•}
    (q : Ok О“)
    вҶ’ ---------------
    О“ вҠў рқҗ” l вҰӮ (1+ l)

  вҠўрқҡ· :
    {l l' : в„•}
    {A : Tm}
    {B : Tm[ 1 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў A вҰӮ l)
    (qвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶[ l ] A) вҠў B [ x ] вҰӮ l')
    вҶ’ -------------------------------
    О“ вҠў рқҡ· l l' A B вҰӮ (max l l')

  вҠўрқӣҢ :
    {l l' : в„•}
    {A : Ty}
    {B : Ty[ 1 ]}
    {b : Tm[ 1 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶[ l ] A) вҠў b [ x ] вҲ¶ B [ x ] вҰӮ l')
    -- helper hypotheses
    (hвӮҖ : О“ вҠў A вҰӮ l)
    (hвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶[ l ] A) вҠў B [ x ] вҰӮ l')
    вҶ’ ------------------------------------------
    О“ вҠў рқӣҢ A b вҲ¶[ max l l' ] рқҡ· l l' A B

  вҠўвҲҷ :
    {l l' : в„•}
    {A : Ty}
    {B : Ty[ 1 ]}
    {a b : Tm}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў b вҲ¶[ max l l' ] рқҡ· l l' A B)
    (qвӮҒ : О“ вҠў a вҲ¶[ l ] A)
    (qвӮӮ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶[ l ] A) вҠў B [ x ] вҰӮ l')
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ -----------------------------------
    О“ вҠў b вҲҷ[ A , B ] a вҲ¶[ l' ] B [ a ]

  вҠўрқҗ„рқҗӘ :
    {l : в„•}
    {A a b : Tm}
    (qвӮҖ : О“ вҠў a вҲ¶[ l ] A)
    (qвӮҒ : О“ вҠў b вҲ¶[ l ] A)
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ -------------------
    О“ вҠў рқҗ„рқҗӘ A a b вҰӮ l

  вҠўрқҗ«рқҗһрқҗҹрқҗҘ :
    {l : в„•}
    {A : Ty}
    {a : Tm}
    (q : О“ вҠў a вҲ¶[ l ] A)
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ ---------------------------
    О“ вҠў рқҗ«рқҗһрқҗҹрқҗҘ A a вҲ¶[ l ] рқҗ„рқҗӘ A a a

  вҠўрқҗ„рқҗҰрқҗ© :
    (q : Ok О“)
    вҶ’ ---------
    О“ вҠў рқҗ„рқҗҰрқҗ© вҰӮ 0

  вҠўрқҗһрқҗҰрқҗ© :
    {l : в„•}
    {A : Ty}
    {e : Tm}
    (qвӮҖ : О“ вҠў A вҰӮ l)
    (qвӮҒ : О“ вҠў e вҲ¶[ 0 ] рқҗ„рқҗҰрқҗ©)
    вҶ’ ---------------------
    О“ вҠў рқҗһрқҗҰрқҗ© A e вҲ¶[ l ] A

  вҠўрқҗҚрқҗҡрқҗӯ :
    (q : Ok О“)
    вҶ’ ---------
    О“ вҠў рқҗҚрқҗҡрқҗӯ вҰӮ 0

  вҠўрқҗірқҗһрқҗ«рқҗЁ :
    (q : Ok О“)
    вҶ’ -----------------
    О“ вҠў рқҗірқҗһрқҗ«рқҗЁ вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ

  вҠўрқҗ¬рқҗ®рқҗңрқҗң :
    {a : Tm}
    (q : О“ вҠў a вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ)
    вҶ’ --------------------
    О“ вҠў рқҗ¬рқҗ®рқҗңрқҗң a вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ

  вҠўрқҗ§рқҗ«рқҗһрқҗң :
    {l : в„•}
    {C : Ty[ 1 ]}
    {cвӮҖ a : Tm}
    {cвӮҠ : Tm[ 2 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў cвӮҖ вҲ¶[ l ] C [ рқҗірқҗһрқҗ«рқҗЁ ])
    (qвӮҒ : вҲҖ x y вҶ’ x # y # S вҶ’
      (О“ вЁҹ x вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ вЁҹ y вҲ¶[ l ] C [ x ]) вҠў
      cвӮҠ [ x ][ y ] вҲ¶[ l ] C [ рқҗ¬рқҗ®рқҗңрқҗң (рқҗҜ x) ])
    (qвӮӮ : О“ вҠў a вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ)
    --  helper hypothesis
    (h : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ) вҠў C [ x ] вҰӮ l)
    вҶ’ --------------------------------------
    О“ вҠў рқҗ§рқҗ«рқҗһрқҗң C cвӮҖ cвӮҠ a вҲ¶[ l ] C [ a ]

  ----------------------------------------------
  -- Definitional equality: О“ вҠў a пјқ a' вҲ¶[ l ] A
  ----------------------------------------------
  Refl :
    {l : в„•}
    {A : Ty}
    {a : Tm}
    (q : О“ вҠў a вҲ¶[ l ] A)
    вҶ’ ------------------
    О“ вҠў a пјқ a вҲ¶ A вҰӮ l

  Symm :
    {l : в„•}
    {A : Ty}
    {a a' : Tm}
    (q : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
    вҶ’ -----------------------
    О“ вҠў a' пјқ a вҲ¶ A вҰӮ l

  Trans :
    {l : в„•}
    {A : Ty}
    {a a' a'' : Tm}
    (qвӮҖ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
    (qвӮҒ : О“ вҠў a' пјқ a'' вҲ¶ A вҰӮ l)
    вҶ’ -------------------------
    О“ вҠў a пјқ a'' вҲ¶ A вҰӮ l

  пјқconv :
    {l : в„•}
    {A A' : Ty}
    {a a' : Tm}
    (qвӮҖ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
    (qвӮҒ : О“ вҠў A пјқ A' вҰӮ l)
    вҶ’ ------------------------
    О“ вҠў a пјқ a' вҲ¶ A' вҰӮ l

  рқҡ·Cong :
    {l l' : в„•}
    {A A' : Ty}
    {B B' : Ty[ 1 ]}
