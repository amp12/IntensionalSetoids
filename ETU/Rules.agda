    О“ вҠў b пјқ b' вҲ¶ рқҡ· l l' A B вҰӮ max l l'

  Reflect :
    {l : в„•}
    {A : Ty}
    {a b e : Tm}
    (qвӮҖ : О“ вҠў a вҲ¶ A вҰӮ l)
    (qвӮҒ : О“ вҠў b вҲ¶ A вҰӮ l)
    (qвӮӮ : О“ вҠў e вҲ¶ рқҗ„рқҗӘ A a b вҰӮ l)
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ -------------------------
    О“ вҠў a пјқ b вҲ¶ A вҰӮ l

  UIP :
    {l : в„•}
    {A : Ty}
    {a b e e' : Tm}
    (qвӮҖ : О“ вҠў a вҲ¶ A вҰӮ l)
    (qвӮҒ : О“ вҠў b вҲ¶ A вҰӮ l)
    (qвӮӮ : О“ вҠў e вҲ¶ рқҗ„рқҗӘ A a b вҰӮ l)
    (qвӮғ : О“ вҠў e' вҲ¶ рқҗ„рқҗӘ A a b вҰӮ l)
    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ ---------------------------
    О“ вҠў e пјқ e' вҲ¶ рқҗ„рқҗӘ A a b вҰӮ l

----------------------------------------------------------------------
-- Definitional equality of contexts
----------------------------------------------------------------------
infix 4 вҠў_пјқ_
data вҠў_пјқ_ : (О“ О“' : Cx) вҶ’ Set where
  пјқв—Ү : вҠў в—Ү пјқ в—Ү
  пјқвЁҹ :
    {l : в„•}
    {О“ О“' : Cx}
    {A A' : Ty}
    {x : рқ”ё}
    (qвӮҖ : вҠў О“ пјқ О“')
    (qвӮҒ : О“ вҠў A пјқ A' вҰӮ l)
    (qвӮӮ : x # (О“ ,  О“'))
    -- helper hypotheses
    (hвӮҖ : О“ вҠў A вҰӮ l)
    (hвӮҒ : О“' вҠў A' вҰӮ l)
    вҶ’ --------------------------------------
    вҠў (О“ вЁҹ x вҲ¶ A вҰӮ l) пјқ (О“' вЁҹ x вҲ¶ A' вҰӮ l)

----------------------------------------------------------------------
-- Context weakening
----------------------------------------------------------------------
infix 4 _в–·_
data _в–·_ : (О” О“ : Cx) вҶ’ Set where
    в–·в—Ү : в—Ү в–· в—Ү
    в–·proj :
      {l : в„•}
      {О” О“ : Cx}
      {A : Ty}
      {x : рқ”ё}
      (qвӮҖ : О” в–· О“)
      (qвӮҒ : О” вҠў A вҰӮ l)
      (qвӮӮ : x # О”)
      вҶ’ ---------------
      О” вЁҹ x вҲ¶ A вҰӮ l в–· О“
    в–·вЁҹ :
      {l : в„•}
      {О” О“ : Cx}
      {A : Ty}
      {x : рқ”ё}
      (qвӮҖ : О” в–· О“)
      (qвӮҒ : О“ вҠў A вҰӮ l)
      (qвӮӮ : x # О”)
      -- helper hypothesis
      (h : О” вҠў A вҰӮ l)
      вҶ’ ---------------------------
      О” вЁҹ x вҲ¶ A вҰӮ l в–· О“ вЁҹ x вҲ¶ A вҰӮ l

----------------------------------------------------------------------
-- Well-typed substitutions
----------------------------------------------------------------------
infix 4 _вҠўЛў_вҲ¶_
data _вҠўЛў_вҲ¶_ (О“' : Cx) : Sb вҶ’ Cx вҶ’ Set where
  в—ҮЛў :
    {Пғ : Sb}
    (q : Ok О“')
    вҶ’ ---------
    О“' вҠўЛў Пғ вҲ¶ в—Ү
  вЁҹЛў :
    {l : в„•}
    {О“ : Cx}
    {Пғ : Sb}
    {A : Ty}
    {x : рқ”ё}
    (qвӮҖ : О“' вҠўЛў Пғ вҲ¶ О“)
