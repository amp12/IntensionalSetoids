    -- helper hypothesis
    (h : О“ вҠў A вҰӮ l)
    вҶ’ -------------------------------------------
    О“ вҠў рқҡ· l l' A B пјқ рқҡ· l l' A' B' вҰӮ (max l l')

  рқӣҢCong :
    {l l' : в„•}
    {A A' : Ty}
    {B : Ty[ 1 ]}
    {b b' : Tm[ 1 ]}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў A пјқ A' вҰӮ l)
    (qвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў b [ x ] пјқ b' [ x ] вҲ¶ B [ x ] вҰӮ l')
    -- helper hypothesis
    (hвӮҖ : О“ вҠў A вҰӮ l)
    (hвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
    вҶ’ -----------------------------------------------------
    О“ вҠў рқӣҢ A b пјқ рқӣҢ A' b' вҲ¶ рқҡ· l l' A B вҰӮ max l l'

  вҲҷCong :
    {l l' : в„•}
    {A A' : Ty}
    {B B' : Ty[ 1 ]}
    {a a' b b' : Tm}
    (S : Fsetрқ”ё)
    (qвӮҖ : О“ вҠў A пјқ A' вҰӮ l)
    (qвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] пјқ B' [ x ] вҰӮ l')
    (qвӮӮ : О“ вҠў b пјқ b' вҲ¶ рқҡ· l l' A B вҰӮ max l l')
    (qвӮғ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
    -- helper hypotheses
    (hвӮҖ : О“ вҠў A вҰӮ l)
    (hвӮҒ : вҲҖ x вҶ’ x # S вҶ’
      (О“ вЁҹ x вҲ¶ A вҰӮ l) вҠў B [ x ] вҰӮ l')
    вҶ’ -----------------------------------------------------
    О“ вҠў b вҲҷ[ A , B ] a пјқ b' вҲҷ[ A' , B' ] a' вҲ¶ B [ a ] вҰӮ l'

  рқҗ„рқҗӘCong :
    {l : в„•}
    {A A' : Ty}
    {a a' b b' : Tm}
    (qвӮҖ : О“ вҠў A пјқ A' вҰӮ l)
    (qвӮҒ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
    (qвӮӮ : О“ вҠў b пјқ b' вҲ¶ A вҰӮ l)
    вҶ’ -----------------------------
    О“ вҠў рқҗ„рқҗӘ A a b пјқ рқҗ„рқҗӘ A' a' b' вҰӮ l

  рқҗ«рқҗһрқҗҹрқҗҘCong :
    {l : в„•}
    {A A' : Ty}
    {a a' : Tm}
    (qвӮҖ : О“ вҠў A пјқ A' вҰӮ l)
    (qвӮҒ : О“ вҠў a пјқ a' вҲ¶ A вҰӮ l)
    вҶ’ ---------------------------------------
    О“ вҠў рқҗ«рқҗһрқҗҹрқҗҘ A a пјқ рқҗ«рқҗһрқҗҹрқҗҘ A' a' вҲ¶ рқҗ„рқҗӘ A a a вҰӮ l

  рқҗһрқҗҰрқҗ©Cong :
    {l : в„•}
    {A A' : Ty}
    {e e' : Tm}
