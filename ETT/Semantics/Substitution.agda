вҹҰconcвҹ§ :
  {l l' : Lvl}
  {О“ : Cx}
  {A : Ty}
  {a : Tm}
  {C : UПү}
  {S : Fam l C}
  {s : Elt l C S}
  {T : Fam l' (C вӢү[ l ] S)}
  {t : Elt l' (C вӢү[ l ] S) T}
  (b : Tm[ 1 ])
  (x : рқ”ё)
  (_ : вҹҰ О“ вЁҹ x вҲ¶ A вҰӮ l вҠў[ l' ] b [ x ] tmвҹ§пјқ (C вӢү[ l ] S , T , t))
  (_ : вҹҰ О“ вҠў[ l ] a tmвҹ§пјқ (C , S , s))
  (_ : x # b)
  вҶ’ --------------------------------------------------------------
  вҹҰ О“ вҠў[ l' ] b [ a ] tmвҹ§пјқ (C , вҹӘ s вҹ« * T , вҹӘ s вҹ« *вӮҒ t)

вҹҰconcвҹ§{l' = l'}{О“}{a = a}{C}{S}{s}{T}{t} b x qвӮҖ qвӮҒ x#b =
  let (q , x#О“)  = вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ qвӮҖ) refl in
  subst (О» b' вҶ’ вҹҰ О“ вҠў[ l' ] b' tmвҹ§пјқ (C , вҹӘ s вҹ« * T , вҹӘ s вҹ« *вӮҒ t))
    (ssb[] x a b x#b)
    (sbвҹҰtmвҹ§ (вҹҰsbвҹ§Update (вҹҰidвҹ§ (okвҹҰtyвҹ§ q)) q qвӮҒ x#О“) qвӮҖ)

вҹҰconcвҹ§ВІ :
  {l l' l'' : Lvl}
  {О“ : Cx}
  {A A' : Ty}
  {a a' : Tm}
  {C : UПү}
  {S : Fam l C}
  {S' : Fam l' (C вӢү[ l ] S)}
  {T : Fam l'' (C вӢү[ l ] S вӢү[ l' ] S')}
  {s : Elt l C S}
  {s' : Elt l' C (вҹӘ s вҹ« * S')}
  {t : Elt l'' (C вӢү[ l ] S вӢү[ l' ] S') T}
  (b : Tm[ 2 ])
  (x x' : рқ”ё)
  (_ : вҹҰ О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ x' вҲ¶ A' вҰӮ l' вҠў[ l'' ] b [ x ][ x' ] tmвҹ§пјқ
    (C вӢү[ l ] S вӢү[ l' ] S' , T , t))
  (_ : вҹҰ О“ вҠў[ l ] a tmвҹ§пјқ (C , S , s))
  (_ : вҹҰ О“ вҠў[ l' ] a' tmвҹ§пјқ (C , вҹӘ s вҹ« * S' , s'))
  (_ : x # b)
  (_ : x' # b)
  вҶ’ --------------------------------------------------------------
  вҹҰ О“ вҠў[ l'' ] b [ a ][ a' ] tmвҹ§пјқ
    (C , вҹӘ s вёҙ s' вҹ« * T , вҹӘ s вёҙ s' вҹ« *вӮҒ t)

вҹҰconcвҹ§ВІ{l'' = l''}{О“}{a = a}{a'}{C}{T = T}{s}{s'}{t}
  b x x' qвӮҖ qвӮҒ qвӮӮ x#b x'#b
  with (q , x'#О“ вҲүвҲӘ x'#x) вҶҗ вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ qвӮҖ) refl
  with  (q' , x#О“) вҶҗ вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ q) refl =
  subst (О» b' вҶ’ вҹҰ О“ вҠў[ l'' ] b' tmвҹ§пјқ
    (C , вҹӘ s вёҙ s' вҹ« * T , вҹӘ s вёҙ s' вҹ« *вӮҒ t))
    (ssb[]ВІ x x' a a' b x#b (x'#b вҲүвҲӘ x'#x))
    (sbвҹҰtmвҹ§
      (вҹҰsbвҹ§Update
        (вҹҰsbвҹ§Update (вҹҰidвҹ§ (okвҹҰtyвҹ§ q')) q' qвӮҒ x#О“)
        q
        qвӮӮ
        (x'#О“ вҲүвҲӘ x'#x))
      qвӮҖ)

----------------------------------------------------------------------
-- A lemma used in proving the semantics is sound for congruence of
-- рқҡ·- and рқӣҢ-terms in Total.agda
----------------------------------------------------------------------
soundвҹҰcxвҹ§ :
  {l l' : Lvl}
  {О“ : Cx}
  {A A' : Ty}
  {b : Tm}
  {x : рқ”ё}
  {C : UПү}
  {S : Fam l C}
  {T : Fam l' (C вӢү[ l ] S)}
  {t : Elt l' (C вӢү[ l ] S) T}
  (_ : вҹҰ О“ вҠў[ l ] A tyвҹ§пјқ (C , S))
  (_ : вҹҰ О“ вҠў[ l ] A' tyвҹ§пјқ (C , S))
  (_ : вҹҰ О“ вЁҹ x вҲ¶ A вҰӮ l вҠў[ l' ] b tmвҹ§пјқ (C вӢү[ l ] S , T , t))
  вҶ’ --------------------------------------------------------
  вҹҰ О“ вЁҹ x вҲ¶ A' вҰӮ l вҠў[ l' ] b tmвҹ§пјқ (C вӢү[ l ] S , T , t)

soundвҹҰcxвҹ§{l}{l'}{О“}{A}{A'}{b}{x}{C}{S}{T}{t} qвӮҖ qвӮҒ qвӮӮ =
  subst (О» b' вҶ’ вҹҰ О“ вЁҹ x вҲ¶ A' вҰӮ l вҠў[ l' ] b' tmвҹ§пјқ
    (C вӢү[ l ] S , T , t))
    (sbUnit b)
    (sbвҹҰtmвҹ§ p qвӮӮ)
  where
  q : вҹҰ О“ cxвҹ§пјқ C
  q = okвҹҰtyвҹ§ qвӮҖ

  x#О“ : x # О“
  x#О“ = ПҖвӮӮ (вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ qвӮӮ) refl)

  p : вҹҰ О“ вЁҹ x вҲ¶ A' вҰӮ l вҠў id вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l) sbвҹ§пјқ
    ((C вӢү[ l ] S , C вӢү[ l ] S) , id)
  p = respвҹҰsbвҹ§
    (вҹҰвЁҹЛўвҹ§
      (wkвҹҰsbвҹ§ x (вҹҰidвҹ§ (okвҹҰtyвҹ§ qвӮҖ)) qвӮҒ x#О“)
      qвӮҖ
      (вҹҰрқҗҜвҹ§ (вҹҰnewвҹ§ qвӮҒ x#О“))
      x#О“)
    ((rflПү (C вӢү[ l ] S) , rflПү (C вӢү[ l ] S)) , О» _ _ u вҶ’ u)
