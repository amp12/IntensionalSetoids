вҹҰsbвҹ§Update :
  {l : Lvl}
  {О” О“ : Cx}
  {Пғ : Sb}
  {A : Ty}
  {a : Tm}
  {x : рқ”ё}
  {D C : UПү}
  {f : Hom D C}
  {S : Fam l C}
  {t : Elt l D (f * S)}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
  (_ : вҹҰ О“ вҠў[ l ] A tyвҹ§пјқ (C , S))
  (_ : вҹҰ О” вҠў[ l ] a tmвҹ§пјқ (D , f * S , t))
  (_ : x # О“)
  вҶ’ -----------------------------------------
  вҹҰ О” вҠў (Пғ вҲҳ/ x := a) вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l) sbвҹ§пјқ
    ((D , C вӢү[ l ] S) , рқ’ёв„ҙрқ“ғрқ“Ҳ f t)

вҹҰsbвҹ§Update{l}{О”}{Пғ = Пғ}{a = a}{x}{D}{f = f}{S}{t} p qвӮҖ qвӮҒ qвӮӮ = вҹҰвЁҹЛўвҹ§
  (вҹҰsbвҹ§Ext p (О» y r вҶ’
     symm (:=Neq {f = Пғ} x y О»{refl вҶ’ вҲүвҶ’В¬вҲҲ qвӮӮ r })))
  qвӮҖ
  (subst (О» a' вҶ’ вҹҰ О” вҠў[ l ] a' tmвҹ§пјқ (D , f * S , t))
    (symm (:=Eq{f = Пғ}{a} x))
    qвӮҒ)
  qвӮӮ

