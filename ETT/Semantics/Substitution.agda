module ETT.Semantics.Substitution where

open import Prelude
open import Setoid
open import WSLN

open import ETT.Syntax
open import ETT.Judgement
open import ETT.Cofinite

open import ETT.Semantics.Relation
open import ETT.Semantics.Ok
open import ETT.Semantics.WellScoped
open import ETT.Semantics.Weakening

----------------------------------------------------------------------
-- The graph of the semantic function for substitutions
----------------------------------------------------------------------
infix 3 вҹҰ_вҠў_вҲ¶_sbвҹ§пјқ

data вҹҰ_вҠў_вҲ¶_sbвҹ§пјқ (О” : Cx) :
  (Пғ : Sb)
  (О“ : Cx)
  (f : вҲЈ в„ұрқ“Ҡрқ“ғ вҲЈ)
  вҶ’ ----------------
  Set
  where
  respвҹҰsbвҹ§ :
    {Пғ : Sb}
    {О“ : Cx}
    {f f' : вҲЈ в„ұрқ“Ҡрқ“ғ вҲЈ}
    (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ f)
    (_ : в„ұрқ“Ҡрқ“ғ вҲӢ f ~ f')
    вҶ’ -----------------------
    вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ f'

  вҹҰв—ҮЛўвҹ§ :
    {Пғ : Sb}
    {D : UПү}
    (p : вҹҰ О” cxвҹ§пјқ D)
    вҶ’ -----------------------------------
    вҹҰ О” вҠў Пғ вҲ¶ в—Ү sbвҹ§пјқ ((D , Unit) , emp D)

  вҹҰвЁҹЛўвҹ§ :
    {l : Lvl}
    {О“ : Cx}
    {Пғ : Sb}
    {A : Ty}
    {x : рқ”ё}
    {D C : UПү}
    {S : Fam l C}
    {f : Hom D C}
    {s : Elt l D (f * S)}
    (pвӮҖ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
    (pвӮҒ : вҹҰ О“ вҠў[ l ] A tyвҹ§пјқ (C , S))
    (pвӮӮ : вҹҰ О” вҠў[ l ] Пғ x tmвҹ§пјқ (D , f * S , s))
    (pвӮғ : x # О“)
    вҶ’ -----------------------------------------
    вҹҰ О” вҠў Пғ вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l) sbвҹ§пјқ
      ((D , C вӢү[ l ] S) , рқ’ёв„ҙрқ“ғрқ“Ҳ f s)

----------------------------------------------------------------------
-- Well-formedness
----------------------------------------------------------------------
okвҹҰsbвҹ§ :
  {О” О“ : Cx}
  {Пғ : Sb}
  {D C : UПү}
  {f : Hom D C}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
  вҶ’ -----------------------------------
  вҹҰ О” cxвҹ§пјқ D

okвҹҰsbвҹ§ (respвҹҰsbвҹ§ q ((e , _) , _)) = respвҹҰcxвҹ§ (okвҹҰsbвҹ§ q) e
okвҹҰsbвҹ§ (вҹҰв—ҮЛўвҹ§ p) = p
okвҹҰsbвҹ§ (вҹҰвЁҹЛўвҹ§ p _ _ _) = okвҹҰsbвҹ§ p

----------------------------------------------------------------------
-- Weakening
----------------------------------------------------------------------
wkвҹҰsbвҹ§ :
  {l : Lvl}
  {О” О“ : Cx}
  {Пғ : Sb}
  {A : Ty}
  (x : рқ”ё)
  {D C : UПү}
  {f : Hom D C}
  {T : Fam l D}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
  (_ : вҹҰ О” вҠў[ l ] A tyвҹ§пјқ (D , T))
  (_ : x # О”)
  вҶ’ -----------------------------------
  вҹҰ О” вЁҹ x вҲ¶ A вҰӮ l вҠў Пғ вҲ¶ О“ sbвҹ§пјқ
    ((D вӢү[ l ] T , C) , f вҲҳ рқ“… T)

wkвҹҰsbвҹ§{l}{О”}{О“}{ПҒ}{A} x {D}{C}{f}{T}
  (respвҹҰsbвҹ§{f = (D' , C') , f'} p ((eвӮҒ , eвӮӮ) , eвӮғ)) q q' =
  respвҹҰsbвҹ§
    {f = (D' вӢү[ l ] T' , C') , f' вҲҳ рқ“… T'}
    {(D вӢү[ l ] T , C) , f вҲҳ рқ“… T}
    (wkвҹҰsbвҹ§ x p (respвҹҰtyвҹ§ q e) q')
    e'
  where
  T' : Fam l D'
  T' = coe (в„ұрқ’¶рқ“Ӯ l) (symПү eвӮҒ) T

  e : ОЈв„ұрқ’¶рқ“Ӯ l вҲӢ (D , T) ~ (D' , T')
  e = (symПү eвӮҒ , coh (в„ұрқ’¶рқ“Ӯ l) (symПү eвӮҒ) T)

  e' : в„ұрқ“Ҡрқ“ғ вҲӢ
    ((D' вӢү[ l ] T' , C') , f' вҲҳ рқ“… T') ~
    ((D  вӢү[ l ] T  , C ) , f  вҲҳ рқ“… T )
  e' = ((eвӮҒ , refl , cohвҒ»В№ (в„ұрқ’¶рқ“Ӯ l) (symПү eвӮҒ) T) , eвӮӮ) ,
    О» c c' u вҶ’ eвӮғ (вҲЈ рқ“… T' вҲЈ c) (вҲЈ рқ“… T вҲЈ c') (ПҖвӮҒ u)

wkвҹҰsbвҹ§ _ (вҹҰв—ҮЛўвҹ§ _) q q' = вҹҰв—ҮЛўвҹ§ (вҹҰвЁҹвҹ§ q q')

wkвҹҰsbвҹ§ x (вҹҰвЁҹЛўвҹ§ pвӮҖ pвӮҒ pвӮӮ pвӮғ) q q' =
  вҹҰвЁҹЛўвҹ§ (wkвҹҰsbвҹ§ x pвӮҖ q q') pвӮҒ (wkвҹҰtmвҹ§ q pвӮӮ q') pвӮғ

----------------------------------------------------------------------
-- Extensionality property of substitution semantics
----------------------------------------------------------------------
вҹҰsbвҹ§Ext :
  {Пғ Пғ' : Sb}
  {О” О“  : Cx}
  {f : вҲЈ в„ұрқ“Ҡрқ“ғ вҲЈ}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ f)
  (_ : вҲҖ x вҶ’ x вҲҲ dom О“ вҶ’ Пғ x вүЎ Пғ' x)
  вҶ’ --------------------------------
  вҹҰ О” вҠў Пғ' вҲ¶ О“ sbвҹ§пјқ f

вҹҰsbвҹ§Ext (respвҹҰsbвҹ§ p e) e' = respвҹҰsbвҹ§ (вҹҰsbвҹ§Ext p e') e
вҹҰsbвҹ§Ext (вҹҰв—ҮЛўвҹ§ p) _ = вҹҰв—ҮЛўвҹ§ p
вҹҰsbвҹ§Ext{Пғ}{Пғ'}{О”} (вҹҰвЁҹЛўвҹ§{x = x} pвӮҖ pвӮҒ pвӮӮ pвӮғ) e
  rewrite e x (вҲҲвҲӘвӮӮ вҲҲпҪӣпҪқ) = вҹҰвЁҹЛўвҹ§
  (вҹҰsbвҹ§Ext pвӮҖ (О» y r вҶ’ e y (вҲҲвҲӘвӮҒ r))) pвӮҒ pвӮӮ pвӮғ

----------------------------------------------------------------------
-- Lifting substitutions
----------------------------------------------------------------------
liftвҹҰsbвҹ§ :
  {l : Lvl}
  {Пғ : Sb}
  {О” О“ : Cx}
  {A : Ty}
  {x x' : рқ”ё}
  {D C : UПү}
  {f : Hom D C}
  {T : Fam l C}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
  (_ : вҹҰ О“ вҠў[ l ] A tyвҹ§пјқ (C , T))
  (_ : x # О“)
  (_ : x' # О”)
  -- helper hypothesis
  (_ : вҹҰ О” вҠў[ l ] Пғ * A tyвҹ§пјқ (D , f * T))
  вҶ’ -------------------------------------------------------------
  вҹҰ О” вЁҹ x' вҲ¶ Пғ * A вҰӮ l вҠў (Пғ вҲҳ/ x := рқҗҜ x') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l) sbвҹ§пјқ
  ((D вӢү[ l ] (f * T) , C вӢү[ l ] T) , f вӢүвҖІ[ l ] T)

liftвҹҰsbвҹ§{l}{Пғ}{О”}{О“}{A}{x}{x'}{D}{C}{f}{T} p q x# x'# h = вҹҰвЁҹЛўвҹ§
  (wkвҹҰsbвҹ§ x' (вҹҰsbвҹ§Ext p e) h x'#)
  q
  q'
  x#
  where
  e : вҲҖ y вҶ’ y вҲҲ dom О“ вҶ’ Пғ y вүЎ (Пғ вҲҳ/ x := рқҗҜ x') y
  e y  yвҲҲО“ with x вүҗ y
  ... | no _ = refl
  ... | equ = Гҳelim (вҲүвҶ’В¬вҲҲ x# yвҲҲО“)

  q' : вҹҰ О” вЁҹ x' вҲ¶ Пғ * A вҰӮ l вҠў[ l ] (Пғ вҲҳ/ x := рқҗҜ x') x tmвҹ§пјқ
    (D вӢү[ l ] (f * T) ,
     (f вҲҳ рқ“… (f * T)) * T ,
     рқ“Ҷ (f * T))
  q' rewrite :=Eq{f = Пғ}{рқҗҜ x'} x = вҹҰрқҗҜвҹ§ (вҹҰnewвҹ§ h x'#)

liftвҹҰsbвҹ§ВІ :
  {l l' : Lvl}
  {Пғ : Sb}
  {О” О“ : Cx}
  {A A' B B' : Ty}
  {x y x' y' : рқ”ё}
  {D C : UПү}
  {f : Hom D C}
  {S : Fam l C}
  {T : Fam l' (C вӢү[ l ] S)}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
  (_ : вҹҰ О“ вҠў[ l ] A tyвҹ§пјқ (C , S))
  (_ : вҹҰ О“ вЁҹ x вҲ¶ A вҰӮ l вҠў[ l' ] B tyвҹ§пјқ (C вӢү[ l ] S , T))
  (_ : x' # О”)
  (_ : y # (О“ , x))
  (_ : y' # (О” , x'))
  (_ : Пғ * A вүЎ A')
  (_ : (Пғ вҲҳ/ x := рқҗҜ x') * B вүЎ B')
  -- helper hypotheses
  (_ : вҹҰ О” вҠў[ l ] A' tyвҹ§пјқ (D , f * S))
  (_ : вҹҰ О” вЁҹ x' вҲ¶ A' вҰӮ l вҠў[ l' ] B' tyвҹ§пјқ
    (D вӢү[ l ] (f * S) , (f вӢүвҖІ[ l ] S) * T))
  вҶ’ ------------------------------------------------------------------
  вҹҰ О” вЁҹ x' вҲ¶ A' вҰӮ l вЁҹ y' вҲ¶ B' вҰӮ l' вҠў
   ((Пғ вҲҳ/ x := рқҗҜ x') вҲҳ/ y := рқҗҜ y') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l') sbвҹ§пјқ
   ((D вӢү[ l ] (f * S) вӢү[ l' ] ((f вӢүвҖІ[ l ] S) * T) ,
     C вӢү[ l ] S вӢү[ l' ] T) ,
     f вӢүвҖІ[ l ] S вӢүвҖІ[ l' ] T)

liftвҹҰsbвҹ§ВІ qвӮҖ qвӮҒ qвӮӮ qвӮғ qвӮ„ qвӮ… refl refl h h' =
  liftвҹҰsbвҹ§
    (liftвҹҰsbвҹ§ qвӮҖ qвӮҒ (ПҖвӮӮ (вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ qвӮӮ) refl)) qвӮғ h)
    qвӮӮ qвӮ„ qвӮ… h'

----------------------------------------------------------------------
-- Semantics of substitution
----------------------------------------------------------------------
sbвҹҰtmвҹ§ :
  {l : Lvl}
  {Пғ : Sb}
  {О” О“ : Cx}
  {a : Tm}
  {D C : UПү}
  {f : Hom D C}
  {T : Fam l C}
  {t : Elt l C T}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
  (_ : вҹҰ О“ вҠў[ l ] a tmвҹ§пјқ (C , T , t))
  вҶ’ -----------------------------------------
  вҹҰ О” вҠў[ l ] Пғ * a tmвҹ§пјқ (D , f * T , f *вӮҒ t)

sbвҹҰvrвҹ§ :
  {l : Lvl}
  {Пғ : Sb}
  {О” О“ : Cx}
  {x : рқ”ё}
  {D C : UПү}
  {f : Hom D C}
  {T : Fam l C}
  {t : Elt l C T}
  (_ : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f))
  (_ : вҹҰ О“ вҠў[ l ] x vrвҹ§пјқ (C , T , t))
  вҶ’ ---------------------------------------
  вҹҰ О” вҠў[ l ] Пғ x tmвҹ§пјқ (D , f * T , f *вӮҒ t)

sbвҹҰtmвҹ§{l}{Пғ}{О”}{О“}{D = D}{C'}{f'}{T'}{t'} p'
  (respвҹҰtmвҹ§{CTt = C , T , t} q (eвӮҒ , eвӮӮ , eвӮғ)) = respвҹҰtmвҹ§
  (sbвҹҰtmвҹ§ p q)
  (rflПү D ,
   (О» c c' u вҶ’ eвӮӮ (вҲЈ f вҲЈ c) (вҲЈ f' вҲЈ c') (e c c' u)) ,
   cng*вӮҒ {l} {T = T} {T'} {t} {t'} f f' e eвӮғ)
  where
  f : Hom D C
  f = coe в„Ӣв„ҙрқ“Ӯ (rflПү D , symПү eвӮҒ) f'

  e : в„Ӣв„ҙрқ“Ӯ вҲӢ (D , C) вёҙ f вүҲ (D , C' ) вёҙ f'
  e = cohвҒ»В№ в„Ӣв„ҙрқ“Ӯ (rflПү D , symПү eвӮҒ) f'

  p : вҹҰ О” вҠў Пғ вҲ¶ О“ sbвҹ§пјқ ((D , C) , f)
  p = respвҹҰsbвҹ§
    p'
    ((rflПү D , symПү eвӮҒ) , coh в„Ӣв„ҙрқ“Ӯ (rflПү D , symПү eвӮҒ) f')

sbвҹҰtmвҹ§ p (вҹҰрқҗ”вҹ§ _) = вҹҰрқҗ”вҹ§ (okвҹҰsbвҹ§ p)

sbвҹҰtmвҹ§{Пғ = Пғ}{О”}{D = D}{f = f} p
  (вҹҰрқҡ·вҹ§{l}{l'}{A}{B}{C}{S}{T} X qвӮҖ qвӮҒ) = respвҹҰtyвҹ§
  (вҹҰрқҡ·вҹ§ (supp (X , B , О”))
    (sbвҹҰtmвҹ§ p qвӮҖ)
    (О»{ x (x#X вҲүвҲӘ x# вҲүвҲӘ x#О”) вҶ’ subst (О» B' вҶ’
      вҹҰ О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вҠў[ l' ] B' tyвҹ§пјқ
      (D вӢү[ l ] (f * S) , f вӢүвҖІ[ l ] S * T))
      (sbUpdate[] Пғ x (рқҗҜ x) B x#)
      (sbвҹҰtmвҹ§
        (liftвҹҰsbвҹ§ p qвӮҖ
          (ПҖвӮӮ (вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ (qвӮҒ x x#X)) refl))
          x#О”
          (sbвҹҰtmвҹ§ p qвӮҖ))
        (qвӮҒ x x#X)) }))
  (rflПү D , (sym (в„ұрқ’¶рқ“Ӯ (max l l') вҖІ D)
    {f * (рқ’«рқ’ҫ l l' S T)}
    {рқ’«рқ’ҫ l l' (f * S) (f вӢүвҖІ[ l ] S * T)}
    (ntrlрқ’«рқ’ҫ l l' S T f)))

sbвҹҰtmвҹ§{Пғ = Пғ}{О”}{D = D}{f = f} p
  (вҹҰрқҗ„рқҗӘвҹ§{l}{C = C}{T}{t}{t'} qвӮҖ qвӮҒ qвӮӮ) = respвҹҰtyвҹ§
  (вҹҰрқҗ„рқҗӘвҹ§ (sbвҹҰtmвҹ§ p qвӮҖ) (sbвҹҰtmвҹ§ p qвӮҒ) (sbвҹҰtmвҹ§ p qвӮӮ))
  (rflПү D , (sym (в„ұрқ’¶рқ“Ӯ l вҖІ D)
    {f * в„°рқ“Ҷ l T t t'}
    {в„°рқ“Ҷ l (f * T) (f *вӮҒ t) (f *вӮҒ t')}
    (ntrlв„°рқ“Ҷ l T t t' f)))

sbвҹҰtmвҹ§ p (вҹҰрқҗҚрқҗҡрқҗӯвҹ§ _) = вҹҰрқҗҚрқҗҡрқҗӯвҹ§ (okвҹҰsbвҹ§ p)

sbвҹҰtmвҹ§{Пғ = Пғ} p (вҹҰрқҗҜвҹ§{x = x} q)
  rewrite вҖҝunit (Пғ x) вҰғ it вҰ„ = sbвҹҰvrвҹ§ p q

sbвҹҰtmвҹ§{Пғ = Пғ}{О”}{О“}{D = D}{f = f} p
  (вҹҰрқӣҢвҹ§{l}{l'}{A = A}{b}{C}{S}{T}{t} X qвӮҖ qвӮҒ) = respвҹҰtmвҹ§
  (вҹҰрқӣҢвҹ§ (supp (X , b , О”))
    (sbвҹҰtmвҹ§ p qвӮҖ)
    (О»{x (x#X вҲүвҲӘ x# вҲүвҲӘ x#О”) вҶ’ subst (О» b' вҶ’
      вҹҰ О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вҠў[ l' ] b' tmвҹ§пјқ
      (D вӢү[ l ] (f * S) , f вӢүвҖІ[ l ] S * T , f вӢүвҖІ[ l ] S *вӮҒ t))
      (sbUpdate[] Пғ x (рқҗҜ x) b x#)
      (sbвҹҰtmвҹ§
        (liftвҹҰsbвҹ§ p qвӮҖ
          (ПҖвӮӮ (вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ (qвӮҒ x x#X)) refl))
          x#О”
          (sbвҹҰtmвҹ§ p qвӮҖ))
        (qвӮҒ x x#X))}))
  (rflПү D ,
   sym (ОЈв„ұрқ’¶рқ“Ӯв„°рқ“Ғрқ“ү (max l l') вҖІ D)
     {f * рқ’«рқ’ҫ l l' S T , f *вӮҒ рқ“Ғрқ’¶рқ“Ӯ l l' S t}
     {рқ’«рқ’ҫ l l' (f * S) (f вӢүвҖІ[ l ] S * T) ,
      рқ“Ғрқ’¶рқ“Ӯ l l' (f * S)(f вӢүвҖІ[ l ] S *вӮҒ t)}
     (ntrlрқ’«рқ’ҫ l l' S T f , ntrlрқ“Ғрқ’¶рқ“Ӯ l l' t f))

sbвҹҰtmвҹ§{Пғ = Пғ}{О”}{О“}{D = D}{f = f} p
  (вҹҰвҲҷвҹ§{l}{l'}{A}{B}{a}{b}{C}{S}{T}{t}{s} X qвӮҖ qвӮҒ qвӮӮ qвӮғ) = respвҹҰtmвҹ§
  (вҹҰвҲҷвҹ§{B = Пғ * B}{t = t'} (supp (X , B , О”))
    (respвҹҰtmвҹ§
      (sbвҹҰtmвҹ§ p qвӮҖ)
      (rflПү D , ntrlрқ’«рқ’ҫ l l' S T f ,
       coh (в„°рқ“Ғрқ“ү (max l l'))
         {y = _ , рқ’«рқ’ҫ l l' (f * S) (f вӢүвҖІ[ l ] S * T)}
         (rflПү D , ntrlрқ’«рқ’ҫ l l' S T f)
         (f *вӮҒ t)))
    (sbвҹҰtmвҹ§ p qвӮҒ)
    (О»{x (x#X вҲүвҲӘ x# вҲүвҲӘ x#О”) вҶ’ subst (О» B' вҶ’
      вҹҰ О” вЁҹ x вҲ¶ Пғ * A вҰӮ l вҠў[ l' ] B' tyвҹ§пјқ
      (D вӢү[ l ] (f * S) , f вӢүвҖІ[ l ] S * T))
      (sbUpdate[] Пғ x (рқҗҜ x) B x#)
      (sbвҹҰtmвҹ§
        (liftвҹҰsbвҹ§ p qвӮҒ
          (ПҖвӮӮ (вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ (qвӮӮ x x#X)) refl))
          x#О”
