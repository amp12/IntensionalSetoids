module Setoid.NatType where

open import Prelude

open import Setoid.Definition
open import Setoid.Universes
open import Setoid.Lift

----------------------------------------------------------------------
-- Natural number type
----------------------------------------------------------------------
nrec :
  (l : в„•)
  (X : в„• вҶ’ U l)
  (xвӮҖ : El l (X 0))
  (xвӮҠ :
    (n : в„•)
    (x : El l (X n))
    вҶ’ --------------
    El l (X (1+ n)) )
  (_ :
    (n : в„•)
    (x x' : El l (X n))
    (_ : в„°рқ“Ғ l вҲӢ X n вёҙ x вүҲ X n вёҙ x')
    вҶ’ -------------------------------------------
    в„°рқ“Ғ l вҲӢ X (1+ n) вёҙ xвӮҠ n x вүҲ X (1+ n) вёҙ xвӮҠ n x')
  (n : в„•)
  вҶ’ ----------------------------------------------
  El l (X n)

nrec l X xвӮҖ xвӮҠ e 0      = xвӮҖ
nrec l X xвӮҖ xвӮҠ e (1+ n) = xвӮҠ n (nrec l X xвӮҖ xвӮҠ e n)

nrecCong :
  {l : в„•}
  {X X' : в„• вҶ’ U l}
  {xвӮҖ : El l (X 0)}
  {xвӮҖ' : El l (X' 0)}
  {xвӮҠ :
    (n : в„•)
    (x : El l (X n))
    вҶ’ --------------
    El l (X (1+ n))  }
  {xвӮҠ' :
    (n : в„•)
    (x : El l (X' n))
    вҶ’ --------------
    El l (X' (1+ n))  }
  {c :
    (n : в„•)
    (x x' : El l (X n))
    (_ : в„°рқ“Ғ l вҲӢ X n вёҙ x вүҲ X n вёҙ x')
    вҶ’ -------------------------------------------
    в„°рқ“Ғ l вҲӢ X (1+ n) вёҙ xвӮҠ n x вүҲ X (1+ n) вёҙ xвӮҠ n x'}
  {c' :
    (n : в„•)
    (x x' : El l (X' n))
    (_ : в„°рқ“Ғ l вҲӢ X' n вёҙ x вүҲ X' n вёҙ x')
    вҶ’ -----------------------------------------------
    в„°рқ“Ғ l вҲӢ X' (1+ n) вёҙ xвӮҠ' n x вүҲ X' (1+ n) вёҙ xвӮҠ' n x'}
  (n n' : в„•)
  (_ :
    (n : в„•)
    вҶ’ --------------
    рқ’° l вҲӢ X n ~ X' n)
  (_ : в„°рқ“Ғ l вҲӢ X 0 вёҙ xвӮҖ вүҲ X' 0 вёҙ xвӮҖ')
  (_ :
    (n : в„•)
    (x : El l (X n))
    (x' : El l (X' n))
    (_ : в„°рқ“Ғ l вҲӢ X n вёҙ x вүҲ X' n вёҙ x')
    вҶ’ ---------------------------------------------
    в„°рқ“Ғ l вҲӢ X (1+ n) вёҙ xвӮҠ n x вүҲ X' (1+ n) вёҙ xвӮҠ' n x')
  (_ : n вүЎ n')
  вҶ’ ------------------------------------------------
  в„°рқ“Ғ l вҲӢ X  n вёҙ nrec l X  xвӮҖ  xвӮҠ  c  n  вүҲ
         X' n' вёҙ nrec l X' xвӮҖ' xвӮҠ' c' n'

nrecCong 0 _ _ e _ refl = e
nrecCong{l}{X}{X'}{xвӮҖ}{xвӮҖ'}{xвӮҠ}{xвӮҠ'}{c}{c'} (1+ n) _ f e g refl = g n
  (nrec l X xвӮҖ xвӮҠ c n)
  (nrec l X' xвӮҖ' xвӮҠ' c' n)
  (nrecCong{l}{X}{X'}{xвӮҖ}{xвӮҖ'}{xвӮҠ}{xвӮҠ'}{c}{c'} n _ f e g refl)

natbetaвӮҖ :
  (l : в„•)
  (X : в„• вҶ’ U l)
  (xвӮҖ : El l (X 0))
  (xвӮҠ :
    (n : в„•)
    (x : El l (X n))
    вҶ’ --------------
    El l (X (1+ n))  )
  (c :
    (n : в„•)
    (x x' : El l (X n))
    (_ : в„°рқ“Ғ l вҲӢ X n вёҙ x вүҲ X n вёҙ x')
    вҶ’ -------------------------------------------
    в„°рқ“Ғ l вҲӢ X (1+ n) вёҙ xвӮҠ n x вүҲ X (1+ n) вёҙ xвӮҠ n x')
  вҶ’ ----------------------------------------------
  в„°рқ“Ғ l вҲӢ X 0 вёҙ nrec l X xвӮҖ xвӮҠ c 0 вүҲ X 0 вёҙ xвӮҖ

natbetaвӮҖ l X xвӮҖ _ _ = hrfl (в„°рқ“Ғ l) (X 0) xвӮҖ

natbetaвӮҠ :
  (l : в„•)
  (X : в„• вҶ’ U l)
  (xвӮҖ : El l (X 0))
  (xвӮҠ :
    (n : в„•)
    (x : El l (X n))
    вҶ’ --------------
    El l (X (1+ n))  )
  (c :
    (n : в„•)
    (x x' : El l (X n))
    (_ : в„°рқ“Ғ l вҲӢ X n вёҙ x вүҲ X n вёҙ x')
    вҶ’ -------------------------------------------
    в„°рқ“Ғ l вҲӢ X (1+ n) вёҙ xвӮҠ n x вүҲ X (1+ n) вёҙ xвӮҠ n x')
  (n : в„•)
  вҶ’ ----------------------------------------------
  в„°рқ“Ғ l вҲӢ X (1+ n) вёҙ nrec l X xвӮҖ xвӮҠ c (1+ n) вүҲ
         X (1+ n) вёҙ xвӮҠ n (nrec l X xвӮҖ xвӮҠ c n)

natbetaвӮҠ l X xвӮҖ xвӮҠ c n =
  hrfl (в„°рқ“Ғ l) (X (1+ n)) (xвӮҠ n (nrec l X xвӮҖ xвӮҠ c n))














