module Semantics.Relation where

open import Prelude
open import Setoid
open import WSLN
open import ETU

open import Semantics.CwF

----------------------------------------------------------------------
-- The graphs of the semantic functions for terms, variables, types
-- and contexts
----------------------------------------------------------------------
infix 3
  вҹҰ_вҠў[_]_вҹ§tmвҶҳ
  вҹҰ_вҠў[_]_вҹ§vrвҶҳ
  вҹҰ_вҠў[_]_вҹ§tyвҶҳ
  вҹҰ_вҹ§cxвҶҳ

-- Terms
data вҹҰ_вҠў[_]_вҹ§tmвҶҳ (О“ : Cx) :
  (l : в„•)
  (a : Tm)
  (CTt : вҲЈ рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вӢү в„°рқ“Ғв„Ҝрқ“Ӯ l вҲЈ)
  вҶ’ ----------------------------
  Set

-- Variables
data вҹҰ_вҠў[_]_вҹ§vrвҶҳ :
  (О“ : Cx)
  (l : в„•)
  (x : рқ”ё)
  (CTt : вҲЈ рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вӢү в„°рқ“Ғв„Ҝрқ“Ӯ l вҲЈ)
  вҶ’ ----------------------------
  Set

-- Types
вҹҰ_вҠў[_]_вҹ§tyвҶҳ :
  (О“ : Cx)
  (l : в„•)
  (A : Ty)
  (CT : вҲЈ рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вҲЈ)
  вҶ’ ------------------
  Set

(вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ(C , T)) =
  -- types are treated as a special case of terms
  -- using fam-as-elt
  вҹҰ О“ вҠў[ 1+ l ] A вҹ§tmвҶҳ((C , рқ“Ҡрқ“ғрқ’ҫрқ“Ӣ l) , T)

-- Contexts
data вҹҰ_вҹ§cxвҶҳ :
  (О“ : Cx)
  (C : вҲЈ рқ’һ вҲЈ)
  вҶ’ ---------
  Set

data вҹҰ_вҠў[_]_вҹ§tmвҶҳ О“ where
  respвҹҰtmвҹ§ :
    {l : в„•}
    {a : Tm}
    {CTt CTt' : вҲЈ рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вӢү в„°рқ“Ғв„Ҝрқ“Ӯ l вҲЈ}
    (_ : вҹҰ О“ вҠў[ l ] a вҹ§tmвҶҳ CTt)
    (_ : рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вӢү в„°рқ“Ғв„Ҝрқ“Ӯ l вҲӢ CTt ~ CTt')
    вҶ’ -----------------------------------
    вҹҰ О“ вҠў[ l ] a вҹ§tmвҶҳ CTt'

  вҹҰрқҗ”вҹ§ :
    {l : в„•}
    {C : вҲЈ рқ’һ вҲЈ}
    (q : вҹҰ О“ вҹ§cxвҶҳ C)
    вҶ’ --------------------------------
    вҹҰ О“ вҠў[ 1+ l ] рқҗ” l вҹ§tyвҶҳ(C , рқ“Ҡрқ“ғрқ’ҫрқ“Ӣ l)

  вҹҰрқҡ·вҹ§ :
    {l l' : в„•}
    {A : Ty}
    {B : Ty[ 1 ]}
    {C : вҲЈ рқ’һ вҲЈ}
    {S : Fam l C}
    {T : Fam l' (C вӢү[ l ] S)}
    (X : Fsetрқ”ё)
    (qвӮҖ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ (C , S))
    (qвӮҒ : вҲҖ x вҶ’ x # X вҶ’
      вҹҰ О“ вЁҹ x вҲ¶[ l ] A вҠў[ l' ] B [ x ] вҹ§tyвҶҳ(C вӢү[ l ] S , T))
    вҶ’ -----------------------------------------------------
     вҹҰ О“ вҠў[ max l l' ] (рқҡ· l l' A B) вҹ§tyвҶҳ(C , рқ’«рқ’ҫ l l' S T)


  вҹҰрқҗ„рқҗӘвҹ§ :
    {l : в„•}
    {A : Ty}
    {a a' : Tm}
    {C : вҲЈ рқ’һ вҲЈ}
    {T : Fam l C}
    {t t' : Elem l C T}
    (qвӮҖ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ(C , T))
    (qвӮҒ : вҹҰ О“ вҠў[ l ] a вҹ§tmвҶҳ((C , T) , t))
    (qвӮӮ : вҹҰ О“ вҠў[ l ] a' вҹ§tmвҶҳ((C , T) , t'))
    вҶ’ ------------------------------------------
    вҹҰ О“ вҠў[ l ] (рқҗ„рқҗӘ A a a') вҹ§tyвҶҳ(C , в„°рқ“Ҷ l T t t')

  вҹҰрқҗ„рқҗҰрқҗ©вҹ§ :
    {C : вҲЈ рқ’һ вҲЈ}
    (q : вҹҰ О“ вҹ§cxвҶҳ C)
    вҶ’ --------------------------
    вҹҰ О“ вҠў[ 0 ] рқҗ„рқҗҰрқҗ© вҹ§tyвҶҳ(C , в„°рқ“Ӯрқ“…)

  вҹҰрқҗҚрқҗҡрқҗӯвҹ§ :
    {C : вҲЈ рқ’һ вҲЈ}
    (q : вҹҰ О“ вҹ§cxвҶҳ C)
    вҶ’ --------------------------
    вҹҰ О“ вҠў[ 0 ] рқҗҚрқҗҡрқҗӯ вҹ§tyвҶҳ(C , рқ’©рқ’¶рқ“ү)

  вҹҰрқҗҜвҹ§ :
    {l : в„•}
    {x : рқ”ё}
    {CTt : вҲЈ рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вӢү в„°рқ“Ғв„Ҝрқ“Ӯ l вҲЈ}
    (q : вҹҰ О“ вҠў[ l ] x вҹ§vrвҶҳ CTt)
    вҶ’ ----------------------------
    вҹҰ О“ вҠў[ l ] рқҗҜ x вҹ§tmвҶҳ CTt

  вҹҰрқӣҢвҹ§ :
    {l l' : в„•}
    {A : Ty}
    {b : Tm[ 1 ]}
    {C : вҲЈ рқ’һ вҲЈ}
    {S : Fam l C}
    {T : Fam l' (C вӢү[ l ] S)}
    {t : Elem l' (C вӢү[ l ] S) T}
    (X : Fsetрқ”ё)
    (qвӮҖ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ(C , S))
    (qвӮҒ : вҲҖ x вҶ’ x # X вҶ’
      вҹҰ О“ вЁҹ x вҲ¶[ l ] A вҠў[ l' ] b [ x ] вҹ§tmвҶҳ
      ((C вӢү[ l ] S , T) , t))
    вҶ’ ------------------------------------
    вҹҰ О“ вҠў[ max l l' ] (рқӣҢ A b)  вҹ§tmвҶҳ
      ((C , рқ’«рқ’ҫ l l' S T) , рқ“Ғрқ’¶рқ“Ӯ l l' S t)

  вҹҰвҲҷвҹ§ :
    {l l' : в„•}
    {A : Ty}
    {B : Ty[ 1 ]}
    {a b : Tm}
    {C : вҲЈ рқ’һ вҲЈ}
    {S : Fam l C}
    {T : Fam l' (C вӢү[ l ] S)}
    {t : Elem (max l l' ) C (рқ’«рқ’ҫ l l' S T)}
    {s : Elem l C S}
    (X : Fsetрқ”ё)
    (qвӮҖ : вҹҰ О“ вҠў[ max l l' ] b вҹ§tmвҶҳ
      ((C , рқ’«рқ’ҫ l l' S T) , t))
    (qвӮҒ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ(C , S))
    (qвӮӮ : вҲҖ x вҶ’ x # X вҶ’
      вҹҰ О“ вЁҹ x вҲ¶[ l ] A вҠў[ l' ] B [ x ] вҹ§tyвҶҳ
      (C вӢү[ l ] S , T))
    (qвӮғ : вҹҰ О“ вҠў[ l ] a вҹ§tmвҶҳ((C , S) , s))
    вҶ’ -------------------------------------
    вҹҰ О“ вҠў[ l' ] (b вҲҷ[ A , B ] a) вҹ§tmвҶҳ
    ((C , вҹӘ s вҹ« * T) , рқ’¶рқ“…рқ“… l l' S T t s)

  вҹҰрқҗ«рқҗһрқҗҹрқҗҘвҹ§ :
    {l : в„•}
    {A : Ty}
    {a : Tm}
    {C : вҲЈ рқ’һ вҲЈ}
    {T : Fam l C}
    {t : Elem l C T}
    (qвӮҖ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ(C , T))
    (qвӮҒ : вҹҰ О“ вҠў[ l ] a вҹ§tmвҶҳ((C , T) , t))
    вҶ’ ------------------------------------
    вҹҰ О“ вҠў[ l ] (рқҗ«рқҗһрқҗҹрқҗҘ A a) вҹ§tmвҶҳ
      ((C , в„°рқ“Ҷ l T t t) , рқ“Үрқ’»рқ“Ғ l T t)

  вҹҰрқҗһрқҗҰрқҗ©вҹ§ :
    {l : в„•}
    {B : Ty}
    {a : Tm}
    {C : вҲЈ рқ’һ вҲЈ}
    {S : Fam l C}
    {e : Elem 0 C в„°рқ“Ӯрқ“…}
    (qвӮҖ : вҹҰ О“ вҠў[ l ] B вҹ§tyвҶҳ(C , S))
    (qвӮҒ : вҹҰ О“ вҠў[ 0 ] a вҹ§tmвҶҳ((C , в„°рқ“Ӯрқ“…) , e))
    вҶ’ --------------------------------------------
    вҹҰ О“ вҠў[ l ] (рқҗһрқҗҰрқҗ© B a) вҹ§tmвҶҳ((C , S) , в„Ҝрқ“Ӯрқ“… l S e)

  вҹҰрқҗірқҗһрқҗ«рқҗЁвҹ§ :
    {C : вҲЈ рқ’һ вҲЈ}
    (q : вҹҰ О“ вҹ§cxвҶҳ C)
    вҶ’ ------------------------------------
    вҹҰ О“ вҠў[ 0 ] рқҗірқҗһрқҗ«рқҗЁ вҹ§tmвҶҳ((C , рқ’©рқ’¶рқ“ү) , рқ“Ҹв„Ҝрқ“Үв„ҙ)

  вҹҰрқҗ¬рқҗ®рқҗңрқҗңвҹ§ :
    {a : Tm}
    {C : вҲЈ рқ’һ вҲЈ}
    {t : Elem 0 C рқ’©рқ’¶рқ“ү}
    (q : вҹҰ О“ вҠў[ 0 ] a  вҹ§tmвҶҳ((C , рқ’©рқ’¶рқ“ү) , t))
    вҶ’ ----------------------------------------
    вҹҰ О“ вҠў[ 0 ] рқҗ¬рқҗ®рқҗңрқҗң a вҹ§tmвҶҳ((C , рқ’©рқ’¶рқ“ү) , рқ“Ҳрқ“Ҡрқ’ёрқ’ё t)

  вҹҰрқҗ§рқҗ«рқҗһрқҗңвҹ§ :
    {l : в„•}
    {B : Ty[ 1 ]}
    {bвӮҖ a : Tm}
    {bвӮҠ : Tm[ 2 ]}
    {C : вҲЈ рқ’һ вҲЈ}
    {S : Fam l (C вӢү[ 0 ] рқ’©рқ’¶рқ“ү)}
    {sвӮҖ : Elem l C (вҹӘ рқ“Ҹв„Ҝрқ“Үв„ҙ вҹ« * S)}
    {sвӮҠ : Elem l (C вӢү[ 0 ] рқ’©рқ’¶рқ“ү вӢү[ l ] S)
      (рқ“… S * рқ’ёв„ҙрқ“ғрқ“Ҳ (рқ“… рқ’©рқ’¶рқ“ү) (рқ“Ҳрқ“Ҡрқ’ёрқ’ё (рқ“Ҷ рқ’©рқ’¶рқ“ү)) * S)}
    {s : Elem 0 C рқ’©рқ’¶рқ“ү}
    (X : Fsetрқ”ё)
    (qвӮҖ : вҲҖ x вҶ’ x # X вҶ’
      вҹҰ О“ вЁҹ x вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ вҠў[ l ] B [ x ] вҹ§tyвҶҳ
      (C вӢү[ 0 ] рқ’©рқ’¶рқ“ү , S))
    (qвӮҒ : вҹҰ О“ вҠў[ l ] bвӮҖ вҹ§tmвҶҳ((C , вҹӘ рқ“Ҹв„Ҝрқ“Үв„ҙ вҹ« * S) , sвӮҖ))
    (qвӮӮ : вҲҖ x y вҶ’ x # y # X вҶ’
      вҹҰ О“ вЁҹ x вҲ¶[ 0 ] рқҗҚрқҗҡрқҗӯ вЁҹ y вҲ¶[ l ] B [ x ] вҠў[ l ]
      bвӮҠ [ x ][ y ] вҹ§tmвҶҳ
        ((C вӢү[ 0 ] рқ’©рқ’¶рқ“ү вӢү[ l ] S ,
         рқ“… S * рқ’ёв„ҙрқ“ғрқ“Ҳ (рқ“… рқ’©рқ’¶рқ“ү) (рқ“Ҳрқ“Ҡрқ’ёрқ’ё (рқ“Ҷ рқ’©рқ’¶рқ“ү)) * S) , sвӮҠ))
    (qвӮғ : вҹҰ О“ вҠў[ 0 ] a вҹ§tmвҶҳ((C , рқ’©рқ’¶рқ“ү) , s))
    вҶ’ -------------------------------------------------
    вҹҰ О“ вҠў[ l ] (рқҗ§рқҗ«рқҗһрқҗң B bвӮҖ bвӮҠ a) вҹ§tmвҶҳ
      ((C ,  вҹӘ s вҹ« * S) , рқ“ғрқ“Үв„Ҝрқ’ё l S sвӮҖ sвӮҠ s)

data вҹҰ_вҠў[_]_вҹ§vrвҶҳ where
  respвҹҰvrвҹ§ :
    {l : в„•}
    {О“ : Cx}
    {x : рқ”ё}
    {CTt CTt' : вҲЈ рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вӢү в„°рқ“Ғв„Ҝрқ“Ӯ l вҲЈ}
    (_ : вҹҰ О“ вҠў[ l ] x вҹ§vrвҶҳ CTt)
    (_ : рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вӢү в„°рқ“Ғв„Ҝрқ“Ӯ l вҲӢ CTt  ~ CTt')
    вҶ’ ------------------------------------
    вҹҰ О“ вҠў[ l ] x вҹ§vrвҶҳ CTt'

  вҹҰnewвҹ§ :
    {l : в„•}
    {О“ : Cx}
    {A : Ty}
    {C : вҲЈ рқ’һ вҲЈ}
    {T : Fam l C}
    {x : рқ”ё}
    (qвӮҖ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ(C , T))
    (qвӮҒ : x # О“)
    вҶ’ -------------------------------
    вҹҰ О“ вЁҹ x вҲ¶[ l ] A вҠў[ l ] x вҹ§vrвҶҳ
      ((C вӢү[ l ] T , рқ“… T * T) , рқ“Ҷ T)

  вҹҰoldвҹ§ :
    {l l' : в„•}
    {О“ : Cx}
    {A' : Ty}
    {C : вҲЈ рқ’һ вҲЈ}
    {T : Fam l C}
    {T' : Fam l' C}
    {t : Elem l C T}
    {x x' : рқ”ё}
    (qвӮҖ : вҹҰ О“ вҠў[ l' ] A' вҹ§tyвҶҳ(C , T'))
    (qвӮҒ : вҹҰ О“ вҠў[ l ] x вҹ§vrвҶҳ((C , T) , t))
    (qвӮӮ : x' # О“)
    вҶ’ -------------------------------------
    вҹҰ О“ вЁҹ x' вҲ¶[ l' ] A' вҠў[ l ] x вҹ§vrвҶҳ
    ((C вӢү[ l' ] T' , рқ“… T' * T) , рқ“… T' *вӮҒ t)

data вҹҰ_вҹ§cxвҶҳ where
  вҹҰв—Үвҹ§ : вҹҰ в—Ү вҹ§cxвҶҳ Unit

  вҹҰвЁҹвҹ§ :
    {l : в„•}
    {О“ : Cx}
    {A : Ty}
    {C : вҲЈ рқ’һ вҲЈ}
    {T : Fam l C}
    {x : рқ”ё}
    (qвӮҖ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ(C , T))
    (qвӮҒ : x # О“)
    вҶ’ -------------------------------
    вҹҰ О“ вЁҹ x вҲ¶[ l ] A вҹ§cxвҶҳ(C вӢү[ l ] T)

-- The "respectfulness" properties for types and contexts are
-- derivable:
respвҹҰtyвҹ§ :
  {О“ : Cx}
  {l : в„•}
  {A : Ty}
  {CT CT' : вҲЈ рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вҲЈ}
  (_ : вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ CT)
  (_ : рқ’һ вӢү в„ұрқ’¶рқ“Ӯ l вҲӢ CT ~ CT')
  вҶ’ ------------------------
  вҹҰ О“ вҠў[ l ] A вҹ§tyвҶҳ CT'

respвҹҰtyвҹ§ q (e , e') = respвҹҰtmвҹ§ q ((e , О» _ _ _ вҶ’ tt) , e')

respвҹҰcxвҹ§ :
  {О“ : Cx}
  {C C' : вҲЈ рқ’һ вҲЈ}
  (_ : вҹҰ О“ вҹ§cxвҶҳ C)
  (_ : рқ’һ вҲӢ C ~ C')
  вҶ’ ----------------
  вҹҰ О“ вҹ§cxвҶҳ C'

respвҹҰcxвҹ§ {C' = Unit} вҹҰв—Үвҹ§ yy = вҹҰв—Үвҹ§
respвҹҰcxвҹ§ {C' = Sigma _ _ _ _} (вҹҰвЁҹвҹ§ qвӮҖ qвӮҒ) (e , refl , e') =
  вҹҰвЁҹвҹ§ (respвҹҰtyвҹ§ qвӮҖ (e , e')) qвӮҒ
