----------------------------------------------------------------------
-- Semantics respects Оұ-equivalence
----------------------------------------------------------------------
вҹҰОұвҹ§ :
  {l l' : в„•}
  {О“ : Cx}
  {A : Ty}
  {C : вҲЈ рқ’һ вҲЈ}
  {S : Fam l C}
  {T : Fam l' (C вӢү[ l ] S)}
  {t : Elem l' (C вӢү[ l ] S) T}
  (b : Tm[ 1 ])
  (x x' : рқ”ё)
  (_ : вҹҰ О“ вҠў[ l ] A tyвҹ§пјқ (C , S))
  (_ : вҹҰ О“ вЁҹ x вҲ¶ A вҰӮ l вҠў[ l' ] b [ x ] tmвҹ§пјқ ((C вӢү[ l ] S , T) , t))
  (_ : x # b)
  (_ : x' # О“)
  вҶ’ ----------------------------------------------------------------
  вҹҰ О“ вЁҹ x' вҲ¶ A вҰӮ l вҠў[ l' ] b [ x' ] tmвҹ§пјқ ((C вӢү[ l ] S , T) , t)

вҹҰОұвҹ§{l}{l'}{О“}{A}{C}{S}{T}{t} b x x' qвӮҖ qвӮҒ x#b x'#О“
  with  (q , x#О“) вҶҗ вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ qвӮҒ) refl = substвӮӮ (О» A' b' вҶ’
    вҹҰ О“ вЁҹ x' вҲ¶ A' вҰӮ l вҠў[ l' ] b' tmвҹ§пјқ ((C вӢү[ l ] S , T) , t))
    (sbUnit A)
    (ssb[] x (рқҗҜ x') b x#b)
    (sbвҹҰtmвҹ§ p qвӮҒ)
  where
  e : в„Ӣв„ҙрқ“Ӯ вҲӢ (C вӢү[ l ] (id * S) , C вӢү[ l ] S) , id вӢүвҖІ[ l ] S вүҲ
    (C вӢү[ l ] S , C вӢү[ l ] S) , id
  e _ _ (u , v , w) with refl вҶҗ ! вҰғ !вүЎ вҰ„ v refl = (u , refl , w)

  p : вҹҰ О“ вЁҹ x' вҲ¶ idЛў * A вҰӮ l вҠў (x := рқҗҜ x') вҲ¶ О“ вЁҹ x вҲ¶ A вҰӮ l sbвҹ§пјқ
    ((C вӢү[ l ] S , C вӢү[ l ] S) , id)
  p = respвҹҰsbвҹ§
    (liftвҹҰsbвҹ§вҒ»{l}{id}{A = A} (вҹҰidвҹ§ (okвҹҰtyвҹ§ qвӮҖ)) qвӮҖ x#О“ x'#О“)
    ((rflб¶ң (C вӢү[ l ] S) , rflб¶ң (C вӢү[ l ] S)) , e)

вҹҰОұвҹ§ВІ :
  {l l' l'' : в„•}
  {О“ : Cx}
  {A B : Ty}
  {C : вҲЈ рқ’һ вҲЈ}
  {S : Fam l C}
  {T : Fam l' (C вӢү[ l ] S)}
  {T' : Fam l'' (C вӢү[ l ] S вӢү[ l' ] T)}
  {t : Elem l'' (C вӢү[ l ] S вӢү[ l' ] T) T'}
  (b : Tm[ 2 ])
  (x y x' y' : рқ”ё)
  (_ : вҹҰ О“ вҠў[ l ] A tyвҹ§пјқ (C , S))
  (_ : вҹҰ О“ вЁҹ x вҲ¶ A вҰӮ l вҠў[ l' ] B tyвҹ§пјқ (C вӢү[ l ] S , T))
  (_ : вҹҰ О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l' вҠў[ l'' ] b [ x ][ y ] tmвҹ§пјқ
    ((C вӢү[ l ] S вӢү[ l' ] T , T') , t))
  (_ : x # b)
  (_ : y # b)
  (_ : x' # О“)
  (_ : y' # (О“ , x'))
  вҶ’ -----------------------------------------------------------
  вҹҰ О“ вЁҹ x' вҲ¶ A вҰӮ l вЁҹ y' вҲ¶ (x := рқҗҜ x') * B вҰӮ l' вҠў[ l'' ]
    b [ x' ][ y' ] tmвҹ§пјқ ((C вӢү[ l ] S вӢү[ l' ] T , T') , t)

вҹҰОұвҹ§ВІ{l}{l'}{l''}{О“}{A}{B}{C}{S}{T}{T'}{t}
  b x y x' y' qвӮҖ qвӮҒ qвӮӮ x#b y#b x'#О“ (y'#О“ вҲүвҲӘ y'#x')
  with  (q , x#О“) вҶҗ вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtyвҹ§ qвӮҒ) refl
  | (q' , y#О“ вҲүвҲӘ y#x) вҶҗ вҹҰвЁҹвҹ§вҒ»В№ (okвҹҰtmвҹ§ qвӮӮ) refl =
  substвӮӮ (О» A' b' вҶ’
    вҹҰ О“ вЁҹ x' вҲ¶ A' вҰӮ l вЁҹ y' вҲ¶ (x := рқҗҜ x') * B вҰӮ l' вҠў[ l'' ] b' tmвҹ§пјқ
    ((C вӢү[ l ] S вӢү[ l' ] T , T') , t))
    (sbUnit A)
    (ssb[]ВІ x y (рқҗҜ x') (рқҗҜ y') b x#b (y#b вҲүвҲӘ y#x))
    (sbвҹҰtmвҹ§ p qвӮӮ)
  where
  e : в„Ӣв„ҙрқ“Ӯ вҲӢ
    (C вӢү[ l ] (id * S) вӢү[ l' ] (id вӢүвҖІ[ l ] S * T) ,
     C вӢү[ l ] S вӢү[ l' ] T) , id вӢүвҖІ[ l ] S вӢүвҖІ[ l' ] T
    вүҲ
    (C вӢү[ l ] S вӢү[ l' ] T ,
     C вӢү[ l ] S вӢү[ l' ] T) , id
  e _ _ (u , v , w) with refl вҶҗ ! вҰғ !вүЎ вҰ„ v refl = (u , refl , w)

  p : вҹҰ О“ вЁҹ x' вҲ¶ idЛў * A вҰӮ l вЁҹ y' вҲ¶ (x := рқҗҜ x') * B вҰӮ l' вҠў
    (x := рқҗҜ x' вҲҳ/ y := рқҗҜ y') вҲ¶ (О“ вЁҹ x вҲ¶ A вҰӮ l вЁҹ y вҲ¶ B вҰӮ l') sbвҹ§пјқ
    ((C вӢү[ l ] S вӢү[ l' ] T , C вӢү[ l ] S вӢү[ l' ] T) , id)
  p = respвҹҰsbвҹ§
    (liftвҹҰsbвҹ§ВІвҒ»{l}{l'}{id}{A = A}{B = B}
      (вҹҰidвҹ§ (okвҹҰtyвҹ§ qвӮҖ))
      q
      qвӮҒ
      x'#О“
      (y#О“ вҲүвҲӘ y#x)
      (y'#О“ вҲүвҲӘ y'#x')
      refl
      refl)
    ((rflб¶ң (C вӢү[ l ] S вӢү[ l' ] T) ,
      rflб¶ң (C вӢү[ l ] S вӢү[ l' ] T)) , e)

вҹҰОұвҹ§ВІ' :
  {l l' l'' : в„•}
  {О“ : Cx}
  {A : Ty}
  {C : вҲЈ рқ’һ вҲЈ}
  {S : Fam l C}
  {T : Fam l' (C вӢү[ l ] S)}
  {T' : Fam l'' (C вӢү[ l ] S вӢү[ l' ] T)}
